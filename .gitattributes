# Repository line-ending policy.
* text=auto

# Keep source code and documentation stable across Windows, WSL, Linux and CI.
.gitattributes text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.svg text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Windows entrypoint scripts may keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets must not be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
*.woff binary
*.woff2 binary
