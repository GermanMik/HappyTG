# Global
NODE_ENV=development
LOG_LEVEL=info
HAPPYTG_API_PORT=4000
HAPPYTG_MINIAPP_PORT=3001
HAPPYTG_BOT_PORT=4100
HAPPYTG_WORKER_PORT=4200
HAPPYTG_POSTGRES_HOST_PORT=5432
HAPPYTG_REDIS_HOST_PORT=6379
HAPPYTG_MINIO_PORT=9000
HAPPYTG_MINIO_CONSOLE_PORT=9001
HAPPYTG_APP_URL=http://localhost:3001
HAPPYTG_API_URL=http://localhost:4000
HAPPYTG_PUBLIC_URL=http://localhost:4000

# Database and queue
DATABASE_URL=postgres://postgres:postgres@localhost:5432/happytg
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_BUCKET=happytg-artifacts

# Telegram
# Create the bot with @BotFather and paste only the token value here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=replace-me

# Auth and control plane
JWT_ISSUER=happytg
JWT_AUDIENCE=happytg-clients
JWT_SIGNING_KEY=replace-me
PAIRING_TOKEN_TTL_SECONDS=900
HOST_ACCESS_TOKEN_TTL_SECONDS=900
HOST_REFRESH_TOKEN_TTL_SECONDS=2592000

# Runtime
# Keep `codex` as the default. HappyTG resolves the Windows npm shim (`codex.cmd`) automatically.
CODEX_CLI_BIN=codex
CODEX_CONFIG_PATH=~/.codex/config.toml
CODEX_SMOKE_PROMPT=Print exactly OK and exit.
DEFAULT_RUNTIME=codex-cli

# Mini App
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=HappyTG

# Host daemon
HOST_DAEMON_DEFAULT_POLL_MS=2000
HOST_DAEMON_MAX_PARALLEL_READS=8
HOST_DAEMON_MUTATION_QUEUE_CONCURRENCY=1

# Optional integrations
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
