# Global
NODE_ENV=development
LOG_LEVEL=info
HAPPYTG_API_PORT=4000
HAPPYTG_MINIAPP_PORT=3001
HAPPYTG_BOT_PORT=4100
HAPPYTG_WORKER_PORT=4200
HAPPYTG_POSTGRES_HOST_PORT=5432
HAPPYTG_REDIS_HOST_PORT=6379
HAPPYTG_MINIO_PORT=9000
HAPPYTG_MINIO_CONSOLE_PORT=9001
HAPPYTG_HTTP_PORT=80
HAPPYTG_HTTPS_PORT=443
HAPPYTG_PROMETHEUS_PORT=9090
HAPPYTG_GRAFANA_PORT=3000
# If port 3001 is occupied locally, set HAPPYTG_MINIAPP_PORT=3007 and keep
# HAPPYTG_APP_URL plus HAPPYTG_DEV_CORS_ORIGINS on the same local port.
# Docker Compose still keeps the Mini App container listener on 3001 and maps
# the chosen host port to it.
# Local development URLs are intentionally HTTP. Telegram web_app buttons and
# menu-button setup require public HTTPS URLs such as the examples below.
# If HAPPYTG_MINIAPP_PORT is changed to 3007, set HAPPYTG_APP_URL to
# http://localhost:3007; keep HAPPYTG_PUBLIC_URL on the API/bot origin.
HAPPYTG_APP_URL=http://localhost:3001
HAPPYTG_API_URL=http://localhost:4000
HAPPYTG_PUBLIC_URL=http://localhost:4000
# Production Telegram Mini App URL. Prefer explicit HTTPS, for example:
# HAPPYTG_MINIAPP_URL=https://happy.example.com/miniapp
# If empty, production derives it from HAPPYTG_PUBLIC_URL + /miniapp when HAPPYTG_PUBLIC_URL is public HTTPS.
HAPPYTG_MINIAPP_URL=
HAPPYTG_BROWSER_API_URL=
HAPPYTG_DOMAIN=happytg.gerta.crazedns.ru
CADDY_ACME_EMAIL=
# Host-run Caddy can use HAPPYTG_MINIAPP_UPSTREAM=127.0.0.1:3007 when the Mini
# App runs directly on that local port. Leave it unset for Docker Compose Caddy,
# where the default upstream is miniapp:3001 inside the Docker network.
# HAPPYTG_MINIAPP_UPSTREAM=127.0.0.1:3007

# Public Telegram Mini App examples:
# If public 443 maps to Caddy:
# HAPPYTG_PUBLIC_URL=https://happytg.gerta.crazedns.ru
# HAPPYTG_MINIAPP_URL=https://happytg.gerta.crazedns.ru/miniapp
# HAPPYTG_APP_URL=https://happytg.gerta.crazedns.ru/miniapp
# If only public HTTPS TCP 8443 maps to Caddy:
# HAPPYTG_HTTPS_PORT=8443
# HAPPYTG_PUBLIC_URL=https://happytg.gerta.crazedns.ru:8443
# HAPPYTG_MINIAPP_URL=https://happytg.gerta.crazedns.ru:8443/miniapp
# HAPPYTG_APP_URL=https://happytg.gerta.crazedns.ru:8443/miniapp

# Database and queue
DATABASE_URL=postgres://postgres:postgres@localhost:5432/happytg
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_BUCKET=happytg-artifacts

# Telegram
# Create the bot with @BotFather and paste only the token value here.
# `auto` uses polling for local/non-public `HAPPYTG_PUBLIC_URL` values and webhook for public HTTPS URLs.
TELEGRAM_UPDATES_MODE=auto
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_WEBHOOK_SECRET=replace-me

# Auth and control plane
JWT_ISSUER=happytg
JWT_AUDIENCE=happytg-clients
JWT_SIGNING_KEY=replace-me
PAIRING_TOKEN_TTL_SECONDS=900
HOST_ACCESS_TOKEN_TTL_SECONDS=900
HOST_REFRESH_TOKEN_TTL_SECONDS=2592000

# Runtime
# Keep `codex` as the default. HappyTG resolves the Windows npm shim (`codex.cmd`) automatically.
CODEX_CLI_BIN=codex
CODEX_CONFIG_PATH=~/.codex/config.toml
CODEX_SMOKE_PROMPT=Print exactly OK and exit.
DEFAULT_RUNTIME=codex-cli

# Mini App
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=HappyTG
# Comma-separated Mini App origins allowed in development. Keep production strict.
HAPPYTG_DEV_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
MINIAPP_INITDATA_MAX_AGE_SECONDS=86400
MINIAPP_LAUNCH_GRANT_TTL_SECONDS=600
MINIAPP_SESSION_TTL_SECONDS=3600
# Defaults to JWT_SIGNING_KEY if empty. Set explicitly in production for launch payload signing.
HAPPYTG_MINIAPP_LAUNCH_SECRET=

# Host daemon
HOST_DAEMON_DEFAULT_POLL_MS=2000
HOST_DAEMON_MAX_PARALLEL_READS=8
HOST_DAEMON_MUTATION_QUEUE_CONCURRENCY=1

# Optional integrations
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
